outcomes <- c("originality", "creativity", "usefulness")
plots <- map(outcomes, function(var) {
summary_df <- compliant_trials_demographics %>%
# Releveling
mutate(condition = fct_relevel(condition, c("Low-Agency",
"High-Agency",
"Control"))) %>%
group_by(submitter_id, condition) %>%
summarize(value = mean(.data[[var]], na.rm = TRUE), .groups = "drop")
ggplot(summary_df, aes(x = condition,
y = value,
color = condition,
fill = condition)) +
# 1. Raw data points in the background
geom_jitter(alpha = 0.75,
width = 0.2,
size = 1.5) +
# 2. Mean points on top (using stat_summary for calculation)
stat_summary(fun = mean,
geom = "point",
shape = 21,
size = 4,
color = "black") +
# 3. Optional: Add error bars for better visualization of the mean
stat_summary(fun.data = mean_cl_boot,
geom = "errorbar",
width = 0.1,
color = "black") +
ylim(c(1, 5)) +
scale_color_manual(values = c("Control" = "#2c3e50",
"High-Agency" = "#18bc9c",
"Low-Agency" = "#e31a1c")) +
scale_fill_manual(values = c("Control" = "#2c3e50",
"High-Agency" = "#18bc9c",
"Low-Agency" = "#e31a1c")) +
labs(x = "", y = str_to_title(var)) +
theme_apa() +
theme(legend.position = "none")
})
