group_by(submitter_id) %>%
mutate(intrinsic_motivation_mean = rowMeans(
across(intrinsic_motivation_1:intrinsic_motivation_4),
na.rm = TRUE
))
str(process_vars)
intrinsic_motivation <- process_vars %>%
# Turn all conv_, consideration_, and intrinsic_items
# to numeric
mutate(across(c(conv_with_ai_1:conv_with_ai_3,
consideration_aid_1:consideration_aid_3,
intrinsic_motivation_1:intrinsic_motivation_4),
as.numeric)) %>%
group_by(submitter_id) %>%
mutate(intrinsic_motivation_mean = rowMeans(
across(intrinsic_motivation_1:intrinsic_motivation_4),
na.rm = TRUE
))
process_vars %>%
group_by(condition) %>%
get_summary_stats(intrinsic_motivation_mean, type="mean_sd")
