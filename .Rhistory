# Doshi operationalization
iriss_doshi <- read_csv("data/doshi_centroid_analysis.csv")
# Set Low-Agency as the reference level
iriss_doshi <- iriss_doshi %>%
mutate(condition = fct_relevel(condition,
"Low-Agency",
"High-Agency",
"Control"))
iriss_doshi_mod <- lmer(similarity_to_cond_obj ~
condition +
(1|submitter_id) +
(1|object),
data=iriss_doshi)
summary(iriss_doshi_mod)
# Export to .tex table
class(iriss_doshi_mod) <- "lmerMod"
stargazer(iriss_doshi_mod, type = "latex", out = "tables/homogeneity.tex")
anova(iriss_doshi_mod, type = 3)
iriss_doshi %>%
group_by(condition) %>%
get_summary_stats(similarity_to_cond_obj,
type="mean_sd") %>%
arrange(desc(mean))
cond_means <- emmeans(iriss_doshi_mod, "condition")
posthoc_results <- pairs(cond_means, adjust="tukey")
print(posthoc_results)
